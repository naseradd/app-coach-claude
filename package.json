{
  "name": "coach-claude",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/shared' build && pnpm -r --filter './packages/web' build && pnpm -r --filter './packages/server' build",
    "dev:web": "pnpm --filter @coach/web dev",
    "dev:server": "pnpm --filter @coach/server dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "deploy": "pnpm build && flyctl deploy --remote-only"
  },
  "devDependencies": {
    "typescript": "5.7.2"
  }
}
