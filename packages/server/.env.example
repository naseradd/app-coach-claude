# Coach Claude server — environment template
# Copy to .env and fill in BEARER_TOKEN.
# Generate a token with: openssl rand -base64 48 | tr -d '\n'

BEARER_TOKEN=
PORT=8080
DB_PATH=./data/coach.db
STATIC_DIR=./dist-web
NODE_ENV=development
# Public origin advertised in OAuth discovery JSON.
# In dev (local), keep the production URL OR override to your tunnel/ngrok URL.
PUBLIC_BASE_URL=https://coach-claude.fly.dev
